# cook your dish here
for _ in range(int(input())):
    n=int(input())
    x=input()
    odd=0
    even=0
    for i in range(97,123):
        temp=x.count(chr(i))
        if temp%2!=0:
            odd+=1
        else:
            even+=1
    if len(set(x))==1:
        if n%2==0:
            print(1)
        else:
            print(2)
    elif odd>1:
        print(0)
    else:
        print(1)
